        None
        None)
      []
      "5::5/128"
      None
      false
      false
      []
      false
      false))

    (Entry "tiger" (NodeProposal
      EdgeTesting
      Max
      Max
      (Machine Metal X86_64 4 "ThinkPadE15Gen2Intel" None None None 12 None)
      (Io
        Colemak
        Uefi
        [
