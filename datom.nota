  ]

  ;; ─── users ──────────────────────────────────────────────────────────
  [
    (Entry "bird" (UserProposal
      Multimedia
      Max
      Colemak
      Emacs
      None
      None
      [
        (Entry "tiger" (UserPubKeyEntry
          "AAAAC3NzaC1lZDI1NTE5AAAAIGhaPt/4ytqbJ9oPk5DE5WEK23N36pZRbvaEuqr/MtfF"
          "943502A0A9D25EF34C16E2ED2A120C26279C4248"))
        (Entry "zeus"  (UserPubKeyEntry
          "AAAAC3NzaC1lZDI1NTE5AAAAIMioAruS5HbgT8hUOVAgKKUP0P6s4gXliVb+AcrtWr4V"
          "962157586FC998370969F675812FE1EBBD9CF8DA"))
      ]))

    (Entry "li" (UserProposal
      Unlimited
      Max
      Colemak
      Emacs
      "LiGoldragon"
      None
      [
        (Entry "ouranos" (UserPubKeyEntry
          "AAAAC3NzaC1lZDI1NTE5AAAAIHEtxRF2wjSD1DzlYCW9BivOsz9X0P95msrbXvGATy/p"
