;; goldragon — production cluster proposal for the LiGoldragon kriom.
;; Schema: horizon-rs ClusterProposal (positional records, source-decl order).
;; See https://github.com/LiGoldragon/horizon-rs docs/DESIGN.md.
;;
;; Conversion notes:
;;  - 2026-04-24: initial datom.nix → datom.nota.
;;  - 2026-04-24: prometheus added (SSH host pubkey from ssh-keyscan;
;;    yggdrasil omitted — legacy 128-char value was a private key);
;;    xerxes removed (decommissioned); maikro removed (test user, never used).
;;  - 2026-04-25: klio removed (decommissioned).
;;  - 2026-04-27: migrated v2 (`<>` + `[name]`) → v3 (`[]` sequences,
;;    `(Entry key value)` map entries, quoted strings) for nota-codec.
;;  - balboa: keyboard/bootloader were absent; defaulted to Qwerty/Uboot.
;;  - prometheus: keyboard absent; defaulted to Qwerty (headless server).
;;  - All users: style absent; defaulted to Emacs (cluster-wide).

(ClusterProposal
  ;; ─── nodes ──────────────────────────────────────────────────────────
  [
    (Entry "balboa" (NodeProposal
      Center
      None
      Min
      (Machine Metal Arm64 4 "rock64" None None None None None)
      (Io
        Qwerty
        Uboot
        [
          (Entry "/" (Disk "/dev/disk/by-label/NIXOS_SD" Ext4 []))
        ]
        [])
      (NodePubKeys
        "AAAAC3NzaC1lZDI1NTE5AAAAIPvxPTAPPKe6Ne9MW4C04Ihe0g4NS12xydci/JW59pIe"
        None
        None)
      []
      None
      None
      false
      false
      []
      false
      false))

    (Entry "ouranos" (NodeProposal
      EdgeTesting
      Large
      Max
      (Machine Metal X86_64 12 "ThinkPadT14Gen5Intel" None None None 12 32)
      (Io
        Colemak
        Uefi
        [
          (Entry "/"     (Disk "/dev/disk/by-uuid/38a88e99-3b6e-4de6-9772-05adddc3a1ca" Ext4 []))
          (Entry "/boot" (Disk "/dev/disk/by-uuid/725A-E86A" Vfat ["fmask=0022" "dmask=0022"]))
        ]
        [])
      (NodePubKeys
        "AAAAC3NzaC1lZDI1NTE5AAAAIP/v8LZFBXHMzflegvnHEgi6EyDn8P5i//iGjboVjtRr"
        "AAqjPi1kOaOWyZrwupTpHNL/7SYjYmaeDu1J+hNtVFA="
        (YggPubKeyEntry
          "6487aabfe0d4f491a2986f4b41388ebcbd3c69a654f32feb9b1fba351bbd590a"
          "201:6de1:5500:7cac:2db9:759e:42d2:fb1d"
          "301:6de1:5500:7cac"))
      []
      "5::3/128"
      None
      true
      false
      []
      false
      true))

    (Entry "prometheus" (NodeProposal
      LargeAiRouter
      Max
      Max
      (Machine Metal X86_64 8 "GMKtec EVO-X2" None None None None 128)
      (Io
        Qwerty
        Uefi
        [
          (Entry "/"     (Disk "/dev/disk/by-uuid/d3ad7f53-2470-4744-9ddf-b183c7c22f31" Btrfs ["subvol=root"]))
          (Entry "/boot" (Disk "/dev/disk/by-uuid/A252-A02B" Vfat []))
          (Entry "/home" (Disk "/dev/disk/by-uuid/d3ad7f53-2470-4744-9ddf-b183c7c22f31" Btrfs ["subvol=home"]))
          (Entry "/nix"  (Disk "/dev/disk/by-uuid/d3ad7f53-2470-4744-9ddf-b183c7c22f31" Btrfs ["subvol=nix"]))
          (Entry "/var"  (Disk "/dev/disk/by-uuid/d3ad7f53-2470-4744-9ddf-b183c7c22f31" Btrfs ["subvol=var"]))
