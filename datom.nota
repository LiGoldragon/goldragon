          "CEEA0DD02CA901E5F71A8CB3EB5C5EB902AA210E"))
      ]))

  ]

  ;; ─── domains ────────────────────────────────────────────────────────
  []

  ;; ─── trust ──────────────────────────────────────────────────────────
  (ClusterTrust
    Max
    []
    [
      (Entry "balboa"     Max)
      (Entry "ouranos"    Max)
      (Entry "prometheus" Max)
      (Entry "tiger"      Max)
      (Entry "zeus"       Max)
    ]
    [
      (Entry "bird"   Med)
      (Entry "li"     Max)
    ]))
