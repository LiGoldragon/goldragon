        None
        (YggPubKeyEntry
          "f40458290d7a2d79efdbef4b5f046fb7f825626eda9d118e4f2b869c105f6ec4"
          "200:17f7:4fad:e50b:a50c:2048:2169:41f7"
          "300:17f7:4fad:e50b"))
      []
